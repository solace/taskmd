#!/bin/sh

# Run taskmd validate before committing
if command -v taskmd >/dev/null 2>&1; then
    taskmd validate
    if [ $? -ne 0 ]; then
        echo "taskmd validate failed. Fix the issues above before committing."
        exit 1
    fi
else
    echo "Warning: taskmd not found, skipping validation"
fi

# Run golangci-lint on staged Go files in apps/cli
if command -v golangci-lint >/dev/null 2>&1; then
    staged=$(git diff --cached --name-only --diff-filter=ACM | grep '^apps/cli/.*\.go$')
    if [ -n "$staged" ]; then
        out=$(cd apps/cli && golangci-lint run 2>&1)
        if [ $? -ne 0 ]; then
            echo "$out"
            echo "golangci-lint failed. Fix the issues above before committing."
            exit 1
        fi
    fi
fi

# Run ESLint and TypeScript type-check on staged web files
staged_web=$(git diff --cached --name-only --diff-filter=ACM | grep '^apps/web/.*\.\(ts\|tsx\)$')
if [ -n "$staged_web" ]; then
    if command -v pnpm >/dev/null 2>&1; then
        out=$(cd apps/web && pnpm lint 2>&1)
        if [ $? -ne 0 ]; then
            echo "$out"
            echo "ESLint (apps/web) failed. Fix the issues above before committing."
            exit 1
        fi

        out=$(cd apps/web && pnpm typeCheck 2>&1)
        if [ $? -ne 0 ]; then
            echo "$out"
            echo "TypeScript type-check (apps/web) failed. Fix the issues above before committing."
            exit 1
        fi
    else
        echo "Warning: pnpm not found, skipping web linting and type-check"
    fi
fi
